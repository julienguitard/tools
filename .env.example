# AI provider (used by rename-papers, extract-from-chrome-to-supabase, query-prolog)
# AI_PROVIDER: "openai" or "anthropic"
AI_PROVIDER=openai
AI_API_KEY=sk-...
AI_MODEL=gpt-4o-mini

# Supabase (used by extract-from-chrome-to-supabase)
SUPABASE_URL=https://YOUR_PROJECT_ID.supabase.co
SUPABASE_API_KEY=YOUR_ANON_KEY
