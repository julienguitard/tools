flowchart TD
    Start([▶ python prolog_query.py family.pl]) --> LoadEnv[Load .env config]
    LoadEnv --> LoadPL["📄 Parse .pl file<br/>Extract predicates & sample facts"]
    LoadPL --> ShowSummary["Show file summary<br/>parent/2, male/1, ancestor/2 …"]
    ShowSummary --> Prompt

    subgraph repl ["REPL loop"]
        Prompt["?- "] --> ReadInput[Read user input]
        ReadInput --> IsCommand{Starts with<br/>: command?}
        IsCommand -- ":quit" --> Exit
        IsCommand -- ":preds" --> ShowPreds["Show predicates"] --> Prompt
        IsCommand -- ":help" --> ShowHelp["Show help"] --> Prompt
        IsCommand -- No --> DetectMode{Looks like<br/>Prolog syntax?}

        DetectMode -- "Yes<br/>parent(X, bob)" --> DirectQuery["Use query as-is"]
        DetectMode -- "No<br/>Who are bob's children?" --> HasAI{AI configured?}

        HasAI -- No --> NoAI["⚠️ No AI — use Prolog syntax"] --> Prompt
        HasAI -- Yes --> Translate[/"🤖 Send to LLM<br/>Natural language + .pl context<br/>→ Prolog query"/]
        Translate --> ShowTranslation["Show: → parent(bob, X)"]

        DirectQuery --> Execute
        ShowTranslation --> Execute

        Execute[/"Run query via swipl<br/>subprocess"/] --> ParseOutput{Parse result}

        ParseOutput -- "Bindings found" --> ShowBindings["X = dave<br/>X = eve"] --> Prompt
        ParseOutput -- "true / false" --> ShowBool["true. / false."] --> Prompt
        ParseOutput -- Error --> ShowError["❌ Error message"] --> Prompt
    end

    ReadInput -- "EOF / Ctrl+C" --> Exit
    Exit(["👋 Exit"])

    style Start fill:#4ade80,color:#000
    style Exit fill:#4ade80,color:#000
    style Translate fill:#818cf8,color:#fff
    style Execute fill:#38bdf8,color:#000
    style LoadPL fill:#38bdf8,color:#000
    style NoAI fill:#facc15,color:#000
    style ShowError fill:#f87171,color:#000
    style repl fill:none,stroke:#64748b,stroke-width:1px,stroke-dasharray: 5 5
